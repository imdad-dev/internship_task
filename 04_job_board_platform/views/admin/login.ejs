<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> · HireLoop</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <div class="auth-wrap">
    <div class="auth-card">
      <div class="auth-brand">
        <div class="mark">H</div>
        <h2 style="font-size:1.3rem;">Admin Login</h2>
        <p>Platform oversight &amp; reporting</p>
      </div>

      <% if (typeof error !== 'undefined' && error && error.length) { %><div class="alert alert-error"><%= error[0] %></div><% } %>

      <form method="POST" action="/admin/login">
        <div class="form-group">
          <label>Username</label>
          <input type="text" class="form-control" name="username" required autofocus />
        </div>
        <div class="form-group">
          <label>Password</label>
          <input type="password" class="form-control" name="password" required />
        </div>
        <button type="submit" class="btn btn-primary btn-block">Sign In</button>
      </form>

      <p class="auth-switch">Default: admin / admin123 (set in .env, run <code>npm run seed</code> first)</p>
      <p class="auth-switch"><a href="/">&larr; Back to website</a></p>
    </div>
  </div>
</body>
</html>
