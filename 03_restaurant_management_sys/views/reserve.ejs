<section class="section" style="padding-top:60px;">
  <div class="container" style="max-width:640px;">
    <div class="section-head">
      <div class="eyebrow" style="justify-content:center;">Book Ahead</div>
      <h2>Reserve a Table</h2>
      <p>Pick a date, time, and party size - we'll hold the best available table for you.</p>
    </div>

    <div class="form-card">
      <form id="reserveForm">
        <div class="form-row">
          <div class="form-group">
            <label>Full Name</label>
            <input type="text" class="form-control" name="customerName" required />
          </div>
          <div class="form-group">
            <label>Phone Number</label>
            <input type="tel" class="form-control" name="phone" required />
          </div>
        </div>

        <div class="form-group">
          <label>Email (optional)</label>
          <input type="email" class="form-control" name="email" />
        </div>

        <div class="form-row">
          <div class="form-group">
            <label>Date</label>
            <input type="date" class="form-control" name="date" required />
          </div>
          <div class="form-group">
            <label>Time</label>
            <input type="time" class="form-control" name="time" required />
          </div>
        </div>

        <div class="form-group">
          <label>Number of Guests</label>
          <input type="number" class="form-control" name="guests" min="1" max="20" value="2" required />
        </div>

        <div class="form-group">
          <label>Choose a Table</label>
          <div class="table-picker">
            <% tables.forEach(function(t) { %>
              <label class="table-chip" data-id="<%= t._id %>" data-capacity="<%= t.capacity %>">
                <input type="radio" name="tableId" value="<%= t._id %>" />
                <strong>T<%= t.tableNumber %></strong>
                <span><%= t.capacity %> seats · <%= t.location %></span>
              </label>
            <% }); %>
          </div>
          <% if (tables.length === 0) { %>
            <p style="color:var(--danger); font-size:0.85rem; margin-top:10px;">No tables are currently available. Please check back shortly or call us directly.</p>
          <% } %>
        </div>

        <div class="form-group">
          <label>Special Request (optional)</label>
          <textarea class="form-control" name="specialRequest" rows="3" placeholder="Birthday, window seat, allergies..."></textarea>
        </div>

        <button type="submit" class="btn btn-primary btn-block">Confirm Reservation</button>
      </form>
    </div>
  </div>
</section>

<script src="/js/reserve.js"></script>
