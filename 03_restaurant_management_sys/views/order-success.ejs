<section class="section" style="padding-top:70px;">
  <div class="container">
    <div class="ticket">
      <div class="check">&#10003;</div>
      <div class="eyebrow" style="justify-content:center;">Order Confirmed</div>
      <h2>Thank you, <%= order.customerName %>!</h2>
      <p style="color:var(--text-muted);">Your order has been sent to the kitchen.</p>
      <div class="ticket-number">#<%= order.orderNumber %></div>

      <div class="ticket-items">
        <% order.items.forEach(function(item) { %>
          <div class="ticket-row">
            <span><%= item.quantity %> × <%= item.name %></span>
            <strong>₹<%= item.price * item.quantity %></strong>
          </div>
        <% }); %>
        <div class="ticket-row" style="border-top:1px solid var(--border); margin-top:10px; padding-top:14px;">
          <strong>Total</strong>
          <strong>₹<%= order.totalAmount %></strong>
        </div>
      </div>

      <p style="color:var(--text-muted); font-size:0.88rem;">
        <%= order.orderType === 'dine-in' ? ('Table ' + (order.table ? order.table.tableNumber : '-')) : 'Takeaway' %>
        &middot; Status: <strong style="color:var(--accent-light); text-transform:capitalize;"><%= order.status %></strong>
      </p>

      <div style="margin-top:26px; display:flex; gap:12px; justify-content:center; flex-wrap:wrap;">
        <a href="/menu" class="btn btn-outline">Order Something Else</a>
        <a href="/" class="btn btn-primary">Back to Home</a>
      </div>
    </div>
  </div>
</section>
