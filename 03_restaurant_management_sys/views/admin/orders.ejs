<div class="panel">
  <div class="panel-head">
    <h3>Orders</h3>
    <select class="form-control" id="statusFilter" style="width:auto;">
      <option value="">All Statuses</option>
      <option value="pending">Pending</option>
      <option value="preparing">Preparing</option>
      <option value="ready">Ready</option>
      <option value="served">Served</option>
      <option value="completed">Completed</option>
      <option value="cancelled">Cancelled</option>
    </select>
  </div>
  <div class="table-wrap">
    <table class="data-table">
      <thead>
        <tr><th>Order #</th><th>Customer</th><th>Type / Table</th><th>Items</th><th>Total</th><th>Payment</th><th>Status</th><th></th></tr>
      </thead>
      <tbody id="ordersTableBody">
        <tr><td colspan="8" style="text-align:center; color:var(--text-muted);">Loading...</td></tr>
      </tbody>
    </table>
  </div>
</div>

<script src="/js/admin-orders.js"></script>
