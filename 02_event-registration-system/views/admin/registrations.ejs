<%- include('../partials/header') %>
<h2 class="mb-4">Registrations</h2>
<div class="table-responsive">
  <table class="table table-hover align-middle bg-white rounded shadow-sm">
    <thead>
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Phone</th>
        <th>Notes</th>
        <th>Registered On</th>
      </tr>
    </thead>
    <tbody id="eventRegistrationsBody">
      <tr><td colspan="5" class="text-center text-muted py-4">Loading registrations...</td></tr>
    </tbody>
  </table>
</div>
<script src="/js/registrations.js"></script>
<script>
  $(function () { loadEventRegistrations("<%= eventId %>"); });
</script>
<%- include('../partials/footer') %>
