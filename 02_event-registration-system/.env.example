# Rename this file to .env before running the project

# Local MongoDB connection string (make sure mongod is running locally)
MONGO_URI=mongodb://127.0.0.1:27017/event_registration_db

# Server port
PORT=5000

# JWT secret used to sign auth tokens (use any long random string)
JWT_SECRET=supersecretjwtkey_change_this
JWT_EXPIRES_IN=7d

# Node environment
NODE_ENV=development
